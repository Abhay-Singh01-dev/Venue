rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /zones/{zoneId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /pipeline/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /activity_feed/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /alerts/{alertId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /simulation/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}